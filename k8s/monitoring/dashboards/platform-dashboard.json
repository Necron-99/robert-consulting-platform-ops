{
  "title": "Robert Consulting \u2014 Platform Overview",
  "uid": "rc-platform-overview",
  "description": "Full platform observability \u2014 APIs, static sites, infrastructure, and Kubernetes",
  "tags": [
    "robert-consulting",
    "platform",
    "overview"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "Namespace",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "query": "label_values(up, namespace)",
        "multi": true,
        "includeAll": true,
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "pluginId": "prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "\ud83d\udd35 Platform Health",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 2,
      "title": "Targets Up",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [],
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "count(up == 1)",
          "legendFormat": "Up",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 3,
      "title": "Targets Down",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "count(up == 0) or vector(0)",
          "legendFormat": "Down",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 4,
      "title": "Node CPU Usage",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "percent",
          "max": 100,
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "Node Memory Usage",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "percent",
          "max": 100,
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
          "legendFormat": "Memory %",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 6,
      "title": "Node Disk Usage",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          },
          "unit": "percent",
          "max": 100,
          "min": 0
        }
      },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} * 100)",
          "legendFormat": "Disk %",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 7,
      "title": "Total Pod Restarts (24h)",
      "type": "stat",
      "gridPos": {
        "x": 20,
        "y": 1,
        "w": 4,
        "h": 4
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "sum(increase(kube_pod_container_status_restarts_total[24h]))",
          "legendFormat": "Restarts",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "\ud83d\udfe2 Threat API",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Threat API \u2014 Request Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 6,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"threat-api\"}[5m])) by (handler, method)",
          "legendFormat": "{{method}} {{handler}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 12,
      "title": "Threat API \u2014 Latency P50/P95/P99",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 6,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"threat-api\"}[5m])) by (le))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"threat-api\"}[5m])) by (le))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"threat-api\"}[5m])) by (le))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 13,
      "title": "Threat API \u2014 Error Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 6,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 2
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"threat-api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"threat-api\"}[5m]))",
          "legendFormat": "Error Rate",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "\ud83d\udd35 Compliance API",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 21,
      "title": "Compliance API \u2014 Request Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"compliance-api\"}[5m])) by (handler, method)",
          "legendFormat": "{{method}} {{handler}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 22,
      "title": "Compliance API \u2014 Latency P50/P95/P99",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 15,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"compliance-api\"}[5m])) by (le))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"compliance-api\"}[5m])) by (le))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"compliance-api\"}[5m])) by (le))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 23,
      "title": "Compliance API \u2014 Error Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 15,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"compliance-api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"compliance-api\"}[5m]))",
          "legendFormat": "Error Rate",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "\ud83c\udf10 Static Sites \u2014 nginx",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 31,
      "title": "Static Sites \u2014 Requests/sec",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(nginx_http_requests_total[5m])) by (namespace)",
          "legendFormat": "{{namespace}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 32,
      "title": "Static Sites \u2014 Active Connections",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 24,
        "w": 8,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "nginx_connections_active{} or nginx_up{}*0",
          "legendFormat": "{{namespace}} active",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 33,
      "title": "Static Sites \u2014 nginx Up",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 24,
        "w": 8,
        "h": 8
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "vertical",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN"
                },
                "1": {
                  "text": "UP"
                }
              }
            }
          ]
        }
      },
      "targets": [
        {
          "expr": "nginx_up",
          "legendFormat": "{{namespace}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 40,
      "type": "row",
      "title": "\u2638\ufe0f Kubernetes \u2014 Pods & Resources",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 41,
      "title": "Pod CPU Usage by Namespace",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cores",
          "custom": {
            "lineWidth": 1
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container!=\"\",container!=\"POD\"}[5m])) by (namespace)",
          "legendFormat": "{{namespace}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 42,
      "title": "Pod Memory Usage by Namespace",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 33,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 1
          }
        }
      },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{container!=\"\",container!=\"POD\"}) by (namespace)",
          "legendFormat": "{{namespace}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 43,
      "title": "Pod Restarts by Namespace",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 41,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "expr": "sum(increase(kube_pod_container_status_restarts_total[1h])) by (namespace)",
          "legendFormat": "{{namespace}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 44,
      "title": "Pod Status",
      "type": "table",
      "gridPos": {
        "x": 12,
        "y": 41,
        "w": 12,
        "h": 8
      },
      "options": {
        "showHeader": true
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left"
          }
        }
      },
      "targets": [
        {
          "expr": "kube_pod_info",
          "legendFormat": "",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "uid": true,
              "instance": true
            },
            "renameByName": {
              "namespace": "Namespace",
              "pod": "Pod",
              "node": "Node",
              "created_by_name": "Controller"
            }
          }
        }
      ]
    },
    {
      "id": 50,
      "type": "row",
      "title": "\ud83d\udda5\ufe0f Node \u2014 CPU / Memory / Disk / Network",
      "gridPos": {
        "x": 0,
        "y": 49,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 51,
      "title": "Node CPU \u2014 All Modes",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 50,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "max": 100,
          "min": 0,
          "custom": {
            "lineWidth": 1
          }
        }
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU Used %",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{mode=\"iowait\"}[5m])) * 100",
          "legendFormat": "IOWait %",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 52,
      "title": "Node Memory",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 50,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 1
          }
        }
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "Total",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "Used",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "Available",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 53,
      "title": "Node Network I/O",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 58,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 1
          }
        }
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|cni.*|flannel.*|cilium.*\"}[5m])",
          "legendFormat": "RX {{device}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|cni.*|flannel.*|cilium.*\"}[5m])",
          "legendFormat": "TX {{device}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          }
        }
      ]
    },
    {
      "id": 54,
      "title": "Node Disk I/O",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 58,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 1
          }
        }
      },
